---
interface RetrievalItem {
  question: string;
  answer: string;
  source?: string;
  lessons_ago?: number;
}

interface Props {
  items: RetrievalItem[];
}

const { items } = Astro.props;
---

<section class="retrieval">
  <header class="r-header">
    <span class="r-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="1 4 1 10 7 10"></polyline>
        <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
      </svg>
    </span>
    <span class="r-title">Kom-igång — från tidigare lektioner</span>
    <span class="r-hint">tänk efter först, kolla sen</span>
  </header>

  <ol class="r-list">
    {items.map((q, i) => (
      <li class="r-item" style={`--i: ${i}`}>
        <div class="q-row">
          <span class="q-num tabular">{i + 1}.</span>
          <div class="q-body">
            <span class="q-text">{q.question}</span>
            {(q.source || q.lessons_ago !== undefined) && (
              <span class="q-meta">
                {q.source && <span class="from">Från: {q.source}</span>}
                {q.lessons_ago !== undefined && q.lessons_ago > 0 && (
                  <span class="ago">
                    · {q.lessons_ago === 1 ? 'förra lektionen' : `${q.lessons_ago} lektioner sedan`}
                  </span>
                )}
              </span>
            )}
          </div>
        </div>
        <details class="q-answer">
          <summary>
            <span class="caret">▶</span>
            <span class="reveal-label">Visa svar</span>
          </summary>
          <p class="ans-text">{q.answer}</p>
        </details>
      </li>
    ))}
  </ol>
</section>

<style>
  .retrieval {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 16px 20px 14px;
    margin: 18px 0;
    box-shadow: var(--shadow-xs), var(--inset-highlight);
    transition: box-shadow var(--duration) var(--ease-out);
  }
  @media (hover: hover) {
    .retrieval:hover { box-shadow: var(--shadow-sm), var(--inset-highlight); }
  }
  .r-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .r-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--accent-soft);
    border-radius: var(--radius-sm);
    color: var(--accent);
    flex-shrink: 0;
  }
  .r-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .r-hint {
    font-size: 11px;
    color: var(--muted-soft);
    margin-left: auto;
    font-style: italic;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  @media (max-width: 540px) {
    .r-hint { display: none; }
  }

  .r-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .r-item {
    opacity: 0;
    animation: rise 400ms var(--ease-out) forwards;
    animation-delay: calc(var(--i, 0) * 80ms + 100ms);
    padding-bottom: 10px;
    border-bottom: 1px dashed var(--line);
  }
  .r-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .q-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 6px;
  }
  .q-num {
    color: var(--muted);
    font-weight: 600;
    flex-shrink: 0;
    min-width: 20px;
  }
  .q-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .q-text {
    font-size: 15px;
    color: var(--ink);
    line-height: 1.55;
  }
  .q-meta {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 2px;
  }
  .q-meta .ago { opacity: 0.85; }

  details.q-answer {
    margin-left: 30px;
  }
  details.q-answer summary {
    cursor: pointer;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    user-select: none;
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    background: var(--accent-soft);
    transition: background var(--duration) var(--ease-out);
  }
  details.q-answer summary:hover {
    background: color-mix(in oklab, var(--accent-soft) 80%, var(--accent) 12%);
  }
  details.q-answer summary::-webkit-details-marker { display: none; }
  details.q-answer .caret {
    transition: transform var(--duration) var(--ease-out);
    display: inline-block;
    font-size: 9px;
  }
  details.q-answer[open] .caret { transform: rotate(90deg); }
  details.q-answer[open] .reveal-label::after {
    content: ":";
  }
  .ans-text {
    margin: 6px 0 0 4px;
    padding: 8px 12px;
    background: var(--success-soft);
    border-radius: var(--radius-sm);
    color: var(--success-vivid);
    font-weight: 600;
    line-height: 1.5;
    font-size: 14px;
    animation: pop-in 250ms var(--ease-out);
  }

  @media (prefers-reduced-motion: reduce) {
    .r-item { opacity: 1; animation: none; }
  }

  @media (max-width: 540px) {
    details.q-answer { margin-left: 0; }
  }
</style>
