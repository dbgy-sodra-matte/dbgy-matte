---
interface RetrievalItem {
  question: string;
  answer: string;
  source?: string;
  lessons_ago?: number;
}

interface Props {
  items: RetrievalItem[];
}

const { items } = Astro.props;
// Rubrik + räknare bor i zon-bandet (Lesson.astro). Här bara frågorna.
---

<section class="retrieval" data-total={items.length}>
  <ol class="r-list">
    {items.map((q, i) => (
      <li class="r-item" style={`--i: ${i}`} data-answer={q.answer}>
        <div class="q-row">
          <span class="q-num tabular">{i + 1}.</span>
          <div class="q-body">
            <span class="q-text">{q.question}</span>
            {(q.source || q.lessons_ago !== undefined) && (
              <span class="q-meta">
                {q.source && <span class="from">Från: {q.source}</span>}
                {q.lessons_ago !== undefined && q.lessons_ago > 0 && (
                  <span class="ago">
                    · {q.lessons_ago === 1 ? 'förra lektionen' : `${q.lessons_ago} lektioner sedan`}
                  </span>
                )}
              </span>
            )}
          </div>
        </div>
        <div class="r-answer-row">
          <input type="text" class="r-input tabular" placeholder="Skriv ditt svar" autocomplete="off" spellcheck="false" aria-label="Ditt svar" />
          <button type="button" class="r-check">Kolla</button>
        </div>
        <p class="r-feedback" data-feedback>&nbsp;</p>
        <details class="q-answer">
          <summary>
            <span class="caret">▶</span>
            <span class="reveal-label">Visa svar</span>
          </summary>
          <p class="ans-text">{q.answer}</p>
        </details>
      </li>
    ))}
  </ol>
</section>

<style>
  .retrieval { margin: 0; }

  .r-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .r-item {
    opacity: 0;
    animation: rise 400ms var(--ease-out) forwards;
    animation-delay: calc(var(--i, 0) * 80ms + 100ms);
    padding-bottom: 10px;
    border-bottom: 1px dashed var(--line);
  }
  .r-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .q-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 6px;
  }
  .q-num {
    color: var(--muted);
    font-weight: 600;
    flex-shrink: 0;
    min-width: 20px;
  }
  .q-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .q-text {
    font-size: 15px;
    color: var(--ink);
    line-height: 1.55;
  }
  .q-meta {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 2px;
  }
  .q-meta .ago { opacity: 0.85; }

  details.q-answer {
    margin-left: 30px;
  }
  details.q-answer summary {
    cursor: pointer;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    user-select: none;
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    background: var(--accent-soft);
    transition: background var(--duration) var(--ease-out);
  }
  details.q-answer summary:hover {
    background: color-mix(in oklab, var(--accent-soft) 80%, var(--accent) 12%);
  }
  details.q-answer summary::-webkit-details-marker { display: none; }
  details.q-answer .caret {
    transition: transform var(--duration) var(--ease-out);
    display: inline-block;
    font-size: 9px;
  }
  details.q-answer[open] .caret { transform: rotate(90deg); }
  details.q-answer[open] .reveal-label::after {
    content: ":";
  }
  .ans-text {
    margin: 6px 0 0 4px;
    padding: 8px 12px;
    background: var(--success-soft);
    border-radius: var(--radius-sm);
    color: var(--success-vivid);
    font-weight: 600;
    line-height: 1.5;
    font-size: 14px;
    animation: pop-in 250ms var(--ease-out);
  }

  @media (prefers-reduced-motion: reduce) {
    .r-item { opacity: 1; animation: none; }
  }

  /* Aktiv återkallning: svarsruta + kolla (Modell 3 retrieval practice) */
  .r-answer-row {
    display: flex;
    gap: 8px;
    margin: 8px 0 0 30px;
    max-width: 420px;
  }
  .r-input {
    flex: 1;
    padding: 8px 12px;
    border: 1.5px solid var(--line);
    border-radius: 4px;
    font-size: 14px;
    background: white;
    color: var(--ink);
    font-family: inherit;
    transition: border-color var(--duration) var(--ease-out), background var(--duration) var(--ease-out);
  }
  .r-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); }
  .r-input.correct { border-color: var(--success); background: var(--success-soft); color: var(--success-vivid); font-weight: 600; }
  .r-input.wrong { border-color: var(--warn); background: var(--warn-soft); color: var(--warn-text); }
  .r-check {
    padding: 8px 14px; background: var(--ink); color: white; border: none;
    border-radius: 4px; font-size: 13px; font-weight: 600; cursor: pointer; flex-shrink: 0;
    transition: background var(--duration) var(--ease-out);
  }
  .r-check:hover { background: color-mix(in oklab, var(--ink) 85%, var(--accent) 15%); }
  .r-feedback { margin: 6px 0 0 30px; font-size: 13px; min-height: 16px; color: var(--muted); }
  .r-feedback.good { color: var(--success-vivid); font-weight: 600; }
  .r-feedback.bad { color: var(--warn-text); }

  @media (max-width: 540px) {
    details.q-answer { margin-left: 0; }
    .r-answer-row, .r-feedback { margin-left: 0; }
  }
</style>

<script>
  import { canonicalize } from '../lib/answer';

  document.querySelectorAll<HTMLElement>('.retrieval').forEach((block) => {
    const total = Number(block.getAttribute('data-total') || '0');
    // Räknaren bor i zon-bandet (Lesson.astro): .zone-repetition [data-rcount]
    const counterWrap = document.querySelector<HTMLElement>('.zone-repetition [data-rcount]');
    const counterEl = counterWrap?.querySelector<HTMLElement>('.rc-done');
    const done = new Set<number>();

    function updateCounter() {
      if (counterEl) counterEl.textContent = String(done.size);
      if (counterWrap && total > 0 && done.size >= total) counterWrap.classList.add('complete');
    }

    block.querySelectorAll<HTMLElement>('.r-item').forEach((item, idx) => {
      const ans = item.getAttribute('data-answer') || '';
      const input = item.querySelector<HTMLInputElement>('.r-input');
      const btn = item.querySelector<HTMLButtonElement>('.r-check');
      const fb = item.querySelector<HTMLElement>('[data-feedback]');
      if (!input || !btn || !fb) return;
      const correct = canonicalize(ans);

      function check() {
        const val = canonicalize(input!.value);
        if (!val) {
          fb!.textContent = 'Skriv något så kollar vi.';
          fb!.className = 'r-feedback bad';
          return;
        }
        if (val === correct) {
          input!.classList.add('correct');
          input!.classList.remove('wrong');
          fb!.textContent = 'Rätt! 🎯';
          fb!.className = 'r-feedback good';
          done.add(idx);
          updateCounter();
        } else {
          input!.classList.remove('correct');
          input!.classList.add('wrong');
          fb!.textContent = 'Inte riktigt — testa igen eller öppna Visa svar.';
          fb!.className = 'r-feedback bad';
        }
      }

      btn.addEventListener('click', check);
      input.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') { e.preventDefault(); check(); }
      });
    });
  });
</script>
