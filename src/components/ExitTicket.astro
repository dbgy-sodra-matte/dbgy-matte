---
interface Props {
  formUrl: string;
  height?: number;
  /** Rubrik och intro kan överstyras per kurs — omläsningen kör "Checkpoint". */
  title?: string;
  intro?: string;
}
const {
  formUrl,
  height = 720,
  title = '🚪 Exit ticket',
  intro = 'Tre snabba frågor + en självmarkering. Tar 5 minuter. Missade du lektionen? Gör den ändå — den ligger öppen i 7 dagar.',
} = Astro.props;

// Ensure embedded=true is set
let embedUrl = formUrl;
if (!embedUrl.includes('embedded=true')) {
  embedUrl += (embedUrl.includes('?') ? '&' : '?') + 'embedded=true';
}
---

<section class="exit-ticket">
  <h2>{title}</h2>
  <p class="intro">{intro}</p>
  <div class="form-frame">
    <iframe
      src={embedUrl}
      title={title}
      width="100%"
      height={height}
      frameborder="0"
      marginheight="0"
      marginwidth="0"
      loading="lazy"
    >Laddar…</iframe>
  </div>
</section>

<style>
  /* Checkpoint = funnelns grind där "klarad" skapas → behåller grön identitet,
   * men i VHS-konsolramen (ink-kant + hård offset + poster-rubrik). */
  .exit-ticket {
    margin: 24px 0 18px;
    background: var(--good);
    color: white;
    padding: 18px;
    border: 1.5px solid var(--ink);
    border-radius: 4px;
    box-shadow: 4px 4px 0 0 rgba(26, 20, 16, 0.18);
  }
  .exit-ticket h2 {
    font-family: var(--font-poster);
    font-size: 22px;
    font-weight: 400;
    margin: 0 0 6px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1;
    color: white;
  }
  .exit-ticket .intro {
    font-size: 13px;
    margin: 0 0 12px;
    opacity: 0.96;
    max-width: 60ch;
  }
  .form-frame {
    background: white;
    border: 1.5px solid var(--ink);
    border-radius: 3px;
    overflow: hidden;
  }
  .form-frame iframe { display: block; width: 100%; border: 0; }
</style>
