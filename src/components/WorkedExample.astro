---
import { marked } from 'marked';

interface Props {
  /** Markdown-källa för exemplet. */
  markdown: string;
  /** Rubrik. Default: "Genomgång — steg för steg". */
  title?: string;
}

const { markdown, title = 'Genomgång — steg för steg' } = Astro.props;

marked.setOptions({
  gfm: true,
  breaks: false,
});

const html = await marked.parse(markdown);
---

<section class="worked-example">
  <header class="we-header">
    <span class="we-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 11l3 3L22 4"></path>
        <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
      </svg>
    </span>
    <span class="we-title">{title}</span>
    <span class="we-hint">titta hit om du var borta</span>
  </header>
  <div class="we-body" set:html={html}></div>
</section>

<style>
  .worked-example {
    margin: 22px 0;
    background: var(--card);
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-md);
    padding: 18px 22px 20px;
    box-shadow: var(--shadow-xs), var(--inset-highlight);
    transition: box-shadow var(--duration) var(--ease-out);
  }
  @media (hover: hover) {
    .worked-example:hover { box-shadow: var(--shadow-sm), var(--inset-highlight); }
  }
  .we-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px dashed var(--line);
  }
  .we-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--accent-soft);
    border-radius: var(--radius-sm);
    color: var(--accent);
    flex-shrink: 0;
  }
  .we-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .we-hint {
    font-size: 11px;
    color: var(--muted);
    margin-left: auto;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  @media (max-width: 540px) {
    .we-hint { display: none; }
  }

  /* Markdown-genererat innehåll */
  .we-body { line-height: 1.65; color: var(--ink); }
  .we-body :first-child { margin-top: 0; }
  .we-body :last-child { margin-bottom: 0; }
  .we-body p { margin: 10px 0; }
  .we-body h1, .we-body h2, .we-body h3, .we-body h4 {
    font-family: var(--font-display);
    color: var(--ink);
    letter-spacing: -0.01em;
    margin: 18px 0 6px;
  }
  .we-body h1 { font-size: 20px; }
  .we-body h2 { font-size: 17px; }
  .we-body h3 { font-size: 15px; }
  .we-body code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg-soft);
    border-radius: 4px;
    padding: 1px 5px;
  }
  .we-body pre {
    background: var(--bg-soft);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.55;
    margin: 12px 0;
  }
  .we-body pre code {
    background: none;
    padding: 0;
  }
  .we-body ul, .we-body ol {
    margin: 10px 0;
    padding-left: 22px;
  }
  .we-body li { margin: 4px 0; }
  .we-body strong { color: var(--ink); font-weight: 700; }
  .we-body table {
    border-collapse: collapse;
    width: 100%;
    margin: 14px 0;
    font-size: 14px;
  }
  .we-body th, .we-body td {
    padding: 8px 12px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
  }
  .we-body th {
    background: var(--bg-soft);
    font-weight: 600;
    color: var(--ink-soft);
    border-bottom: 2px solid var(--line-strong);
  }
  .we-body td:first-child {
    font-weight: 600;
    color: var(--ink);
    white-space: nowrap;
  }
  .we-body blockquote {
    margin: 14px 0;
    padding: 10px 14px;
    border-left: 3px solid var(--accent);
    background: var(--accent-soft);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--ink);
    font-style: italic;
  }
</style>
