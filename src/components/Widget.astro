---
interface Props {
  src: string;
  /** Startad höjd innan widget rapporterat sin verkliga via postMessage. */
  height?: number;
  title?: string;
}

const { src, height = 480, title = 'Interaktiv övning' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const widgetUrl = `${base}/widgets/${src}.html`;
---

<section class="widget-section">
  <header class="w-header">
    <span class="w-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"></circle>
        <path d="M12 1v6m0 10v6m11-11h-6M7 12H1m17-7l-4 4m-6 6l-4 4m0-14l4 4m6 6l4 4"></path>
      </svg>
    </span>
    <span class="w-title">Utforska visuellt</span>
    <span class="w-hint">lek runt — det är gjort för det</span>
  </header>
  <div class="widget-frame" data-widget-frame style={`min-height: ${height}px;`}>
    <iframe
      src={widgetUrl}
      title={title}
      width="100%"
      height={height}
      loading="lazy"
      sandbox="allow-scripts allow-same-origin"
      data-widget-iframe
    ></iframe>
  </div>
</section>

<script>
  // Auto-resize widget-iframes från postMessage.
  // Widgeten skickar { type: 'widget-height', height: <px> } — vi sätter iframens
  // höjd och frame:s min-height så att ingen scroll uppstår inuti.
  window.addEventListener('message', (e) => {
    const data = e.data;
    if (!data || data.type !== 'widget-height' || typeof data.height !== 'number') return;
    const iframes = document.querySelectorAll<HTMLIFrameElement>('iframe[data-widget-iframe]');
    iframes.forEach((iframe) => {
      if (iframe.contentWindow !== e.source) return;
      const h = Math.max(120, Math.ceil(data.height) + 4); // liten marginal för ev. border
      iframe.style.height = h + 'px';
      const frame = iframe.closest<HTMLElement>('[data-widget-frame]');
      if (frame) frame.style.minHeight = h + 'px';
    });
  });
</script>

<style>
  .widget-section {
    margin: 22px 0;
  }
  .w-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .w-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--accent-soft);
    border-radius: var(--radius-sm);
    color: var(--accent);
    flex-shrink: 0;
  }
  .w-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .w-hint {
    font-size: 11px;
    color: var(--muted-soft);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-left: auto;
    font-style: italic;
  }
  .widget-frame {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--card);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm), var(--inset-highlight);
    transition: box-shadow var(--duration) var(--ease-out);
  }
  @media (hover: hover) {
    .widget-frame:hover { box-shadow: var(--shadow-md), var(--inset-highlight); }
  }
  .widget-frame iframe {
    display: block;
    width: 100%;
    border: 0;
  }
  @media (max-width: 540px) {
    .w-hint { display: none; }
  }
</style>
