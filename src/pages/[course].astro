---
import '../styles/global.css';
import { courses, SITE_TITLE } from '../site.config';
import { sequences } from '../data/sequence';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return Object.keys(courses).map((code) => ({ params: { course: code } }));
}

const { course: courseCode } = Astro.params;
const course = courses[courseCode!];
const allLessons = await getCollection('lessons');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Ordna efter sequence.ts (speglar Classroom 1:1). Gruppera i moment i den ordningen.
const bySlug = new Map(allLessons.map((l) => [l.slug as string, l]));
const seq = sequences[courseCode!] ?? [];
const ordered = seq.map((s) => bySlug.get(s)).filter(Boolean) as typeof allLessons;

// Fallback: lektioner i kursen som saknas i sekvensen läggs sist
const inSeq = new Set(ordered.map((l) => l.slug));
const leftover = allLessons
  .filter((l) => l.slug.startsWith(`${courseCode}/`) && !inSeq.has(l.slug))
  .sort((a, b) => a.data.lesson_number - b.data.lesson_number);
const allOrdered = [...ordered, ...leftover];

type Moment = { moment: string; title: string; lessons: typeof allLessons };
const moments: Moment[] = [];
for (const l of allOrdered) {
  const last = moments[moments.length - 1];
  if (last && last.moment === l.data.moment) last.lessons.push(l);
  else moments.push({ moment: l.data.moment, title: l.data.moment_title, lessons: [l] });
}

// Liten tagg per sidtyp utifrån titeln
function kindOf(title: string): string | null {
  const t = title.toLowerCase();
  if (t.includes('redo att tenta')) return 'Pre-test';
  if (t.includes('kursprov')) return 'Kursprov';
  if (t.includes('dugga')) return 'Dugga';
  if (t.includes('prov')) return 'Prov';
  return null;
}
const isMilestone = (title: string) => kindOf(title) === 'Pre-test';

const themeClass = course?.theme ? `theme-${course.theme}` : '';
const unitLabel = course?.unitLabel ?? 'Lektion';
const unitLabelLc = unitLabel.toLowerCase();
// Räkna "riktiga" delmoment (pre-test/redo-att-tenta är en milstolpe, inte ett delmoment)
const realTotal = allOrdered.filter((l) => !isMilestone(l.data.title)).length;
const areaIcon: Record<string, string> = {
  algebra: '∑', ekonomi: '💰', sannolikhet: '🎲', funktioner: '📈',
};
---

<!doctype html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{course?.title ?? courseCode} — {SITE_TITLE}</title>
  <meta name="description" content={`Kursöversikt för ${course?.title ?? courseCode}`} />
</head>
<body class={themeClass}>
  <nav class="breadcrumb" aria-label="Brödsmulor">
    <a href={`${base}/`}>{SITE_TITLE}</a>
    <span class="sep">›</span>
    <span class="here current">{course?.title ?? courseCode}</span>
  </nav>

  <main class="course-page">
    <header class="course-header">
      <div class="course-meta">Kursöversikt · {moments.length} områden · {realTotal} {unitLabelLc}er</div>
      <h1>{course?.title ?? courseCode}</h1>
      <div class="tracking-bar" aria-hidden="true"></div>

      {realTotal > 0 && (
        <div class="hero-progress" id="hero" data-total={realTotal}>
          <div class="hero-row">
            <span class="hero-label" id="hero-label">Din träningsresa</span>
            <span class="hero-count"><span class="hero-done tabular" id="hero-done">0</span> / {realTotal} tränade</span>
          </div>
          <div class="hero-bar"><div class="hero-bar-fill" id="hero-fill" style="width:0%"></div></div>
          <p class="hero-hint" id="hero-hint">Träna klart delmomenten här — gör sedan checkpointen längst ner på varje sida för att låsa det i ditt kvitto.</p>
        </div>
      )}

      {course?.kvittoWebAppUrl !== undefined && (
        <a href={`${base}/${courseCode}/mitt-kvitto`} class="kvitto-btn">
          📋 Mitt kvitto — se dina framsteg
        </a>
      )}
    </header>

    <ol class="moment-list">
      {moments.map((m, mi) => {
        const real = m.lessons.filter((l) => !isMilestone(l.data.title)).length;
        return (
        <li class="moment-block" data-real={real}>
          <div class="moment-head">
            <span class="moment-num" aria-hidden="true">{areaIcon[m.moment] ?? mi + 1}</span>
            <h2 class="moment-title">{m.title}</h2>
            <span class="moment-progress"><span class="mp-done tabular">0</span>/<span class="tabular">{real}</span></span>
          </div>
          <div class="moment-bar"><div class="moment-bar-fill"></div></div>
          <span class="moment-stamp" aria-hidden="true">TRÄNAT</span>
          <ul class="unit-list">
            {m.lessons.map((l) => {
              const kind = kindOf(l.data.title);
              const milestone = isMilestone(l.data.title);
              return (
                <li class={`unit-node${milestone ? ' milestone' : ''}`} data-done-key={`${base}/${l.slug}`}>
                  <a href={`${base}/${l.slug}`} class="unit-link">
                    <span class="node-status" aria-hidden="true"></span>
                    <span class="unit-title">{l.data.title}</span>
                    {kind && <span class={`unit-tag tag-${kind.toLowerCase().replace(/[^a-z]/g, '')}`}>{kind}</span>}
                    <span class="unit-state" aria-hidden="true"></span>
                  </a>
                </li>
              );
            })}
          </ul>
        </li>
        );
      })}
    </ol>

    <footer class="course-foot">
      <a href={`${base}/`} class="back-link">← Alla kurser</a>
    </footer>
  </main>

  <script is:inline>
    (function () {
      function isDone(key) {
        try { return localStorage.getItem('dbgy-matte:done:' + key) === '1'; } catch (e) { return false; }
      }
      var heroTotal = 0, heroDone = 0;

      document.querySelectorAll('.moment-block').forEach(function (block) {
        var real = parseInt(block.getAttribute('data-real') || '0', 10);
        var doneInArea = 0;
        block.querySelectorAll('.unit-node').forEach(function (node) {
          var key = node.getAttribute('data-done-key');
          if (key && isDone(key)) {
            node.classList.add('done');
            if (!node.classList.contains('milestone')) doneInArea++;
          }
        });
        var mpDone = block.querySelector('.mp-done');
        if (mpDone) mpDone.textContent = String(doneInArea);
        var fill = block.querySelector('.moment-bar-fill');
        if (fill) fill.style.width = (real ? Math.round((doneInArea / real) * 100) : 0) + '%';
        if (real > 0 && doneInArea === real) block.classList.add('complete');
        heroTotal += real; heroDone += doneInArea;
      });

      var hero = document.getElementById('hero');
      if (hero) {
        var total = parseInt(hero.getAttribute('data-total') || '0', 10) || heroTotal;
        var doneEl = document.getElementById('hero-done');
        var fillEl = document.getElementById('hero-fill');
        var hintEl = document.getElementById('hero-hint');
        var labelEl = document.getElementById('hero-label');
        if (doneEl) doneEl.textContent = String(heroDone);
        var pct = total ? Math.round((heroDone / total) * 100) : 0;
        if (fillEl) fillEl.style.width = pct + '%';
        var funnel = ' Gör checkpointen på varje delmoment för att låsa det i Mitt kvitto.';
        var label = 'Din träningsresa', hint = 'Träna klart delmomenten här.' + funnel;
        if (heroDone === 0) { label = 'Nystartad 🚀'; hint = 'Börja med ett delmoment och träna.' + funnel; }
        else if (pct === 100) { label = 'Allt tränat! 🎉'; hint = 'Du har tränat klart alla delmoment. Gör checkpoints och anmäl dig till tenta-av!'; hero.classList.add('done-all'); }
        else if (pct >= 75) { label = 'Snart i mål'; hint = 'Bara några delmoment kvar att träna.' + funnel; }
        else if (pct >= 50) { label = 'Över halvvägs'; hint = 'Mer än halva resan tränad. Fin rytm.' + funnel; }
        else if (pct >= 25) { label = 'Bra fart'; hint = 'Du är i gång — fortsätt delmoment för delmoment.' + funnel; }
        else { label = 'I gång'; hint = 'Bra start.' + funnel; }
        if (labelEl) labelEl.textContent = label;
        if (hintEl) hintEl.textContent = hint;
      }
    })();
  </script>
</body>
</html>

<style>
  .course-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 8px 18px 48px;
  }
  .course-header { margin: 18px 0 26px; }
  .course-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
    font-weight: 500;
  }
  .course-header h1 {
    font-family: var(--font-poster);
    text-transform: uppercase;
    font-size: clamp(34px, 8vw, 54px);
    line-height: 0.9;
    letter-spacing: 0.01em;
    margin: 8px 0 0;
    color: var(--ink);
  }
  .tracking-bar {
    height: 4px;
    margin: 14px 0 18px;
    background: linear-gradient(90deg, var(--accent) 0%, var(--warm) 55%, transparent 100%);
    transform-origin: left;
    animation: track-in 600ms var(--ease-out) both;
  }
  @keyframes track-in { from { transform: scaleX(0); } to { transform: scaleX(1); } }

  /* ─── Hero-progress (hela kursens resa) ─────────────── */
  .hero-progress {
    background: #fffdf8;
    border: 1.5px solid var(--ink);
    border-radius: 4px;
    padding: 16px 18px;
    box-shadow: 4px 4px 0 0 rgba(26, 20, 16, 0.14);
    transition: box-shadow var(--duration) var(--ease-out), border-color var(--duration) var(--ease-out);
  }
  .hero-progress.done-all {
    border-color: var(--success);
    box-shadow: var(--shadow-sm), var(--success-glow), var(--inset-highlight);
  }
  .hero-row { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
  .hero-label { font-family: var(--font-mono); font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.16em; color: var(--accent); }
  .hero-count { font-size: 14px; color: var(--muted); font-weight: 600; }
  .hero-done { font-size: 20px; font-weight: 800; color: var(--accent); }
  .hero-bar {
    height: 12px; background: var(--bg-soft); border-radius: 999px; overflow: hidden;
    margin: 10px 0 8px; box-shadow: inset 0 1px 2px hsl(var(--shadow-color) / 0.12);
  }
  .hero-bar-fill {
    height: 100%; border-radius: 999px;
    background: linear-gradient(90deg, var(--warm) 0%, var(--accent) 100%);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.25);
    transition: width 700ms var(--ease-spring);
  }
  .hero-progress.done-all .hero-bar-fill { background: linear-gradient(90deg, var(--success) 0%, var(--success-vivid) 100%); }
  .hero-hint { font-size: 13px; color: var(--ink-soft); margin: 0; }

  .kvitto-btn {
    display: inline-flex; align-items: center; gap: 8px; margin-top: 16px;
    padding: 11px 18px; background: var(--accent); color: white; text-decoration: none;
    font-weight: 600; font-size: 14px; border-radius: var(--radius-sm); box-shadow: var(--shadow-xs);
    transition: background var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
  }
  .kvitto-btn:hover { background: var(--accent-strong); transform: translateY(-1px); }

  /* ─── Områdeslista ──────────────────────────────────── */
  .moment-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 20px; }
  .moment-block {
    position: relative;
    background: #fffdf8; border: 1.5px solid var(--ink); border-left: 10px solid var(--accent);
    border-radius: 4px; padding: 16px 18px;
    box-shadow: 4px 4px 0 0 rgba(26, 20, 16, 0.12);
    transition: box-shadow var(--duration) var(--ease-out), border-color var(--duration) var(--ease-out);
  }
  .moment-block.complete { border-left-color: var(--success); box-shadow: 5px 5px 0 0 rgba(16, 185, 129, 0.28); }

  .moment-head { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
  .moment-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: 6px;
    background: var(--accent); color: #fff;
    font-weight: 700; font-size: 17px; flex-shrink: 0;
  }
  .moment-block.complete .moment-num { background: var(--success); color: #fff; }
  .moment-title { font-family: var(--font-poster); text-transform: uppercase; font-size: 21px; line-height: 1; letter-spacing: 0.01em; margin: 0; flex: 1; color: var(--ink); }
  .moment-progress { font-family: var(--font-mono); font-size: 13px; color: var(--accent); font-weight: 500; letter-spacing: 0.04em; }

  .moment-bar { height: 6px; background: var(--bg-soft); border-radius: 999px; overflow: hidden; margin-bottom: 14px; }
  .moment-bar-fill {
    height: 100%; width: 0%; border-radius: 999px; background: var(--accent);
    transition: width 600ms var(--ease-spring);
  }
  .moment-block.complete .moment-bar-fill { background: var(--success); }

  /* "KLART"-stämpel när hela området är klart */
  .moment-stamp {
    position: absolute; top: 14px; right: 16px;
    font-size: 11px; font-weight: 800; letter-spacing: 0.12em;
    color: var(--success-vivid); border: 2px solid var(--success-vivid);
    padding: 2px 8px; border-radius: 6px; transform: rotate(7deg) scale(0.6);
    opacity: 0; transition: opacity var(--duration) var(--ease-out), transform var(--duration) var(--ease-spring);
    pointer-events: none;
  }
  .moment-block.complete .moment-stamp { opacity: 1; transform: rotate(7deg) scale(1); }

  /* ─── Delmoment-noder (resans steg) ─────────────────── */
  .unit-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; position: relative; }
  .unit-link {
    display: flex; align-items: center; gap: 12px; padding: 10px 12px;
    border: 1px solid var(--line); border-radius: var(--radius-sm); text-decoration: none;
    color: var(--ink); background: var(--bg);
    transition: background var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
  }
  .unit-link:hover { background: var(--accent-soft); border-color: var(--accent); transform: translateX(2px); }

  /* Status-cirkel (blir ✅ när klar) */
  .node-status {
    width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0;
    border: 2px solid var(--line-strong); background: var(--card);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 12px; color: white; transition: background var(--duration) var(--ease-out), border-color var(--duration) var(--ease-out);
  }
  .unit-node.done .node-status { background: var(--success); border-color: var(--success); }
  .unit-node.done .node-status::after { content: '✓'; font-weight: 800; }
  .unit-node.milestone .node-status { border-radius: 6px; border-style: dashed; }
  .unit-node.milestone.done .node-status::after { content: '🏁'; font-size: 11px; }

  .unit-title { flex: 1; font-weight: 600; font-size: 14px; }
  .unit-node.done .unit-title { color: var(--muted); }

  .unit-state { white-space: nowrap; text-align: right; color: var(--muted); font-size: 16px; flex-shrink: 0; opacity: 0; transition: opacity var(--duration-fast); }
  .unit-state::after { content: '→'; }
  .unit-link:hover .unit-state { opacity: 1; }
  .unit-node.done .unit-state { opacity: 1; color: var(--success-vivid); }
  .unit-node.done .unit-state::after { content: 'Tränat'; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }

  .unit-tag {
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700;
    padding: 3px 8px; border-radius: 999px; background: var(--bg-soft); color: var(--muted); flex-shrink: 0;
  }
  .tag-dugga { background: var(--warm-soft); color: var(--warn-text); }
  .tag-prov, .tag-kursprov { background: var(--accent-soft); color: var(--accent-strong); }
  .tag-pretest { background: var(--success-soft); color: var(--success-vivid); }

  .course-foot { margin-top: 28px; }
  .back-link { color: var(--muted); text-decoration: none; font-size: 14px; }
  .back-link:hover { color: var(--accent); }

  .breadcrumb {
    font-size: 12px; color: var(--muted); padding: 10px 18px;
    max-width: var(--content-width); margin: 0 auto;
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .breadcrumb a { color: var(--muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { margin: 0 6px; opacity: 0.5; }
  .breadcrumb .current { color: var(--ink); font-weight: 600; }

  @media (max-width: 540px) {
    .course-header h1 { font-size: 26px; }
  }
</style>
