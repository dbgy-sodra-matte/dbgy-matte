---
import '../styles/global.css';
import { courses, SITE_TITLE } from '../site.config';
import { getCollection } from 'astro:content';

const lessons = await getCollection('lessons');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Antal byggda sidor per kurs (för en liten statusrad på varje kort)
const countByCourse: Record<string, number> = {};
for (const l of lessons) {
  const code = l.slug.split('/')[0];
  countByCourse[code] = (countByCourse[code] ?? 0) + 1;
}
---

<!doctype html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{SITE_TITLE}</title>
</head>
<body>
  <main class="home">
    <header class="home-header">
      <div class="home-meta">DBGY Stockholm Södra · Matematik</div>
      <h1>{SITE_TITLE}</h1>
      <p class="home-intro">Välj din kurs. Varje kurs har en egen översikt där du ser allt innehåll i ordning.</p>
    </header>

    <div class="course-cards">
      {Object.values(courses).map((course) => {
        const n = countByCourse[course.code] ?? 0;
        return (
          <a href={`${base}/${course.code}`} class={`course-card${course.theme ? ' theme-' + course.theme : ''}`}>
            <span class="card-title">{course.title}</span>
            <span class="card-status">
              {n > 0 ? `${n} ${(course.unitLabel ?? 'lektion').toLowerCase()}er` : 'Under uppbyggnad'}
            </span>
            <span class="card-go">Öppna kursen →</span>
          </a>
        );
      })}
    </div>

    <footer class="home-foot">
      <p>Byggt med Astro · hostat på GitHub Pages · ägs av dbgy-sodra-matte</p>
    </footer>
  </main>
</body>
</html>

<style>
  .home {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 32px 18px 48px;
  }
  .home-meta {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
    font-weight: 600;
  }
  .home-header h1 {
    font-family: var(--font-display);
    font-size: 34px;
    margin: 6px 0 10px;
  }
  .home-intro { color: var(--ink-soft); font-size: 15px; margin: 0 0 28px; }

  .course-cards {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .course-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--card);
    text-decoration: none;
    color: var(--ink);
    box-shadow: var(--shadow-xs), var(--inset-highlight);
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
    border-top: 3px solid var(--accent);
  }
  .course-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md), var(--inset-highlight);
    border-color: var(--accent);
  }
  /* VHS-kursen får sin egen accent redan på startsidan */
  .course-card.theme-vhs { border-top-color: #b91c1c; }
  .course-card.theme-vhs:hover { border-color: #b91c1c; }
  .card-title { font-size: 19px; font-weight: 700; font-family: var(--font-display); }
  .card-status {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    font-weight: 600;
  }
  .card-go { margin-top: 8px; font-size: 14px; font-weight: 600; color: var(--accent); }
  .course-card.theme-vhs .card-go { color: #b91c1c; }

  .home-foot {
    margin-top: 40px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 12px;
    text-align: center;
  }
</style>
