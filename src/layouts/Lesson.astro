---
import '../styles/global.css';
import { courses, SITE_TITLE } from '../site.config';
import Breadcrumb from '../components/Breadcrumb.astro';
import SuccessCriteria from '../components/SuccessCriteria.astro';
import RetrievalBlock from '../components/RetrievalBlock.astro';
import Genomgang from '../components/Genomgang.astro';
import Widget from '../components/Widget.astro';
import WorkedExample from '../components/WorkedExample.astro';
import Exercise from '../components/Exercise.astro';
import ExerciseProgress from '../components/ExerciseProgress.astro';
import ExitTicket from '../components/ExitTicket.astro';
import MomentProgress from '../components/MomentProgress.astro';
import LessonFooter from '../components/LessonFooter.astro';

interface ExerciseFM {
  equation: string;
  hint1?: string;
  hint2?: string;
  hint3?: string;
  answer?: string | string[];
  solution?: string;
}

interface Frontmatter {
  title: string;
  course: string;
  moment: string;
  moment_title: string;
  lesson_number: number;
  lesson_total: number;
  success_criteria: string[];
  retrieval?: { question: string; answer: string; source?: string; lessons_ago?: number }[];
  video?: string;
  widget?: string;
  widget_height?: number;
  worked_example?: string;
  worked_example_title?: string;
  exercises?: {
    E?: ExerciseFM[];
    C?: ExerciseFM[];
    A?: ExerciseFM[];
  };
  exit_ticket_form?: string;
  exit_ticket_height?: number;
  prev?: string;
  next?: string;
  prev_lesson_title?: string;
  next_lesson_title?: string;
}

interface Props {
  frontmatter: Frontmatter;
}

const { frontmatter } = Astro.props;
const course = courses[frontmatter.course];
const themeClass = course?.theme ? `theme-${course.theme}` : '';
const unitLabel = course?.unitLabel ?? 'Lektion';

// Plattna ut E → C → A till en numrerad lista, behåll nivåstämpel
type FlatExercise = ExerciseFM & { level: 'E' | 'C' | 'A' };
const flatExercises: FlatExercise[] = [];
if (frontmatter.exercises) {
  (frontmatter.exercises.E ?? []).forEach(e => flatExercises.push({ ...e, level: 'E' }));
  (frontmatter.exercises.C ?? []).forEach(e => flatExercises.push({ ...e, level: 'C' }));
  (frontmatter.exercises.A ?? []).forEach(e => flatExercises.push({ ...e, level: 'A' }));
}

const counts = {
  E: frontmatter.exercises?.E?.length ?? 0,
  C: frontmatter.exercises?.C?.length ?? 0,
  A: frontmatter.exercises?.A?.length ?? 0,
};
const totalExercises = flatExercises.length;
const exercisesHaveAnswers = flatExercises.some(ex => !!ex.answer);

// Stagger-index för sektionerna
let sectionIdx = 0;
const stagger = () => `--i: ${sectionIdx++}`;
---

<!doctype html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#2a5d8f" />
  <title>{frontmatter.title} — {course?.title ?? frontmatter.course}</title>
  <meta name="description" content={`Lektion ${frontmatter.lesson_number} av ${frontmatter.lesson_total} — ${frontmatter.moment_title}`} />
</head>
<body class={themeClass}>
  {course && (
    <Breadcrumb
      siteTitle={SITE_TITLE}
      course={course}
      momentTitle={frontmatter.moment_title}
      lessonTitle={frontmatter.title}
    />
  )}

  <main class="lesson stagger">
    <header class="lesson-header" style={stagger()}>
      <div class="lesson-meta">
        {frontmatter.moment_title} · {unitLabel} {frontmatter.lesson_number} av {frontmatter.lesson_total}
      </div>
      <h1>{frontmatter.title}</h1>
    </header>

    <div style={stagger()}>
      <SuccessCriteria items={frontmatter.success_criteria} />
    </div>

    {frontmatter.retrieval && frontmatter.retrieval.length > 0 && (
      <div style={stagger()}>
        <RetrievalBlock items={frontmatter.retrieval} />
      </div>
    )}

    {/* Teorigenomgång — kollapsibel by default. Innehåller markdown + worked example. */}
    <details class="theory-block" style={stagger()}>
      <summary>
        <span class="theory-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
        </span>
        <span class="theory-title">Teorigenomgång och exempel</span>
        <span class="theory-hint">klicka för att läsa</span>
      </summary>
      <div class="theory-body">
        {frontmatter.video && <Genomgang videoUrl={frontmatter.video} />}
        <article class="lesson-content">
          <slot />
        </article>
      </div>
    </details>

    {frontmatter.widget && (
      <div style={stagger()}>
        <Widget src={frontmatter.widget} height={frontmatter.widget_height ?? 480} />
      </div>
    )}

    {frontmatter.worked_example && (
      <div style={stagger()}>
        <WorkedExample
          markdown={frontmatter.worked_example}
          title={frontmatter.worked_example_title}
        />
      </div>
    )}

    {flatExercises.length > 0 && (
      <section class="exercises-section" style={stagger()}>
        <div class="exercises-header">
          <div class="ex-title-block">
            <h2 class="ex-section-title">Övningsuppgifter</h2>
            <p class="ex-section-sub">Träna i lugn ordning — klart är klart.</p>
          </div>
          <div class="ex-overview" aria-label="KM-nivåfördelning">
            {counts.E > 0 && <span class="count-pill level-e">{counts.E} × Ep</span>}
            {counts.C > 0 && <span class="count-pill level-c">{counts.C} × Cp</span>}
            {counts.A > 0 && <span class="count-pill level-a">{counts.A} × Ap</span>}
          </div>
        </div>

        {exercisesHaveAnswers && (
          <ExerciseProgress total={totalExercises} />
        )}

        <ol class="exercises-list">
          {flatExercises.map((ex, i) => (
            <Exercise
              number={i + 1}
              level={ex.level}
              equation={ex.equation}
              hint1={ex.hint1}
              hint2={ex.hint2}
              hint3={ex.hint3}
              answer={ex.answer}
              solution={ex.solution}
            />
          ))}
        </ol>
      </section>
    )}

    {frontmatter.exit_ticket_form && (
      <div style={stagger()}>
        <ExitTicket
          formUrl={frontmatter.exit_ticket_form}
          height={frontmatter.exit_ticket_height ?? 720}
        />
      </div>
    )}

    <div style={stagger()}>
      <MomentProgress current={frontmatter.lesson_number} total={frontmatter.lesson_total} />
    </div>

    <div style={stagger()}>
      <LessonFooter
        courseCode={frontmatter.course}
        momentDir={frontmatter.moment}
        prev={frontmatter.prev}
        next={frontmatter.next}
        prevTitle={frontmatter.prev_lesson_title}
        nextTitle={frontmatter.next_lesson_title}
      />
    </div>
  </main>
</body>
</html>

<style>
  /* ─── Theory block — kollapsibel teorigenomgång ──────── */
  details.theory-block {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    margin: 18px 0;
    overflow: hidden;
    box-shadow: var(--shadow-xs), var(--inset-highlight);
    transition: box-shadow var(--duration) var(--ease-out);
  }
  details.theory-block[open] {
    box-shadow: var(--shadow-sm), var(--inset-highlight);
  }
  details.theory-block summary {
    cursor: pointer;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    list-style: none;
    user-select: none;
  }
  details.theory-block summary:hover {
    background: color-mix(in oklab, var(--card) 90%, var(--accent-soft) 100%);
  }
  details.theory-block summary::-webkit-details-marker { display: none; }
  details.theory-block summary::after {
    content: "▾";
    margin-left: auto;
    color: var(--muted);
    transition: transform var(--duration) var(--ease-out);
  }
  details.theory-block[open] summary::after { transform: rotate(180deg); }

  .theory-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--accent-soft);
    border-radius: var(--radius-sm);
    color: var(--accent);
    flex-shrink: 0;
  }
  .theory-title {
    font-weight: 600;
    font-size: 14px;
    color: var(--ink);
  }
  .theory-hint {
    font-size: 11px;
    color: var(--muted);
    margin-left: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  details.theory-block[open] .theory-hint { display: none; }
  .theory-body {
    padding: 6px 22px 22px;
    border-top: 1px dashed var(--line);
    animation: pop-in 300ms var(--ease-out);
  }

  /* ─── Exercises section — KM-style numbered list ────── */
  .exercises-section {
    margin: 28px 0;
  }
  .exercises-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }
  .ex-title-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ex-section-title {
    font-size: 22px;
    font-weight: 700;
    margin: 0;
    color: var(--ink);
    letter-spacing: -0.015em;
    font-family: var(--font-display);
  }
  .ex-section-sub {
    font-size: 13px;
    color: var(--muted);
    margin: 0;
  }
  .ex-overview {
    display: flex;
    gap: 6px;
  }
  .count-pill {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    color: white;
    font-family: var(--font-display);
    box-shadow: var(--shadow-xs);
  }
  .count-pill.level-e { background: var(--level-e); }
  .count-pill.level-c { background: var(--level-c); }
  .count-pill.level-a { background: var(--level-a); }

  ol.exercises-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
